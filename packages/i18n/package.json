{
  "name": "@gc-digital-talent/i18n",
  "license": "AGPL-3.0",
  "type": "module",
  "version": "1.0.0",
  "types": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx",
    "./en.json": "./src/lang/en.json",
    "./fr.json": "./src/lang/fr.json",
    "./frCompiled.json": "./src/lang/frCompiled.json"
  },
  "scripts": {
    "prettier": "prettier --check . --ignore-path=../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path=../../.prettierignore",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "tsc": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check-intl": "tsx ./src/cli.ts",
    "intl-extract": "formatjs extract './src/**/*.{ts,tsx}' --ignore './**/*.d.ts' --out-file src/lang/en.json --id-interpolation-pattern [sha512:contenthash:base64:6]",
    "intl-compile": "formatjs compile src/lang/fr.json --ast --out-file src/lang/frCompiled.json"
  },
  "dependencies": {
    "@gc-digital-talent/graphql": "workspace:*",
    "@gc-digital-talent/helpers": "workspace:*",
    "@gc-digital-talent/logger": "workspace:*",
    "@gc-digital-talent/rich-text-elements": "workspace:*",
    "react-router": "^8.0.1"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.16.11",
    "@gc-digital-talent/eslint-config": "workspace:*",
    "@gc-digital-talent/vitest-helpers": "workspace:*",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.6.0",
    "history": "^5.3.0",
    "jsdom": "^29.1.1",
    "js-yaml": "^5.2.1",
    "json-stable-stringify": "^1.3.0",
    "react": "^19.2.7",
    "react-intl": "^10.1.14",
    "react-router": "^8.0.1",
    "tsconfig": "workspace:*",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yargs": "^18.0.0"
  }
}
