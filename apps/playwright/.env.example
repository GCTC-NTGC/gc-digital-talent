# Timeouts in ms
# See: https://playwright.dev/docs/test-timeouts
#TEST_TIMEOUT=30000
#EXPECT_TIMEOUT=5000

# Base URL for the app under test. Defaults to http://localhost:8000.
#BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Only needed when running against UAT via `pnpm e2e:playwright:uat`
# (which loads .env.uat instead of this file).
# Not required for local or CI runs.
# ---------------------------------------------------------------------------

# Secret shared between the Playwright runner and the app's /refresh endpoint.
# Stored in Azure Key Vault; ask a team member for the UAT value.
#TESTING_ENDPOINT_SECRET=

# UUIDs of real users in the UAT environment, used to authenticate during setup.
#PLAYWRIGHT_PLATFORM_ADMIN_SUB=
#PLAYWRIGHT_COMMUNITY_ADMIN_SUB=
#PLAYWRIGHT_APPLICANT_SUB=
