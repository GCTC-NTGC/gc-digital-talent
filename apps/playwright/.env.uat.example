# Copy this file to .env.uat and fill in real values from Azure Key Vault / team member.
# Load with: PLAYWRIGHT_ENV_FILE=.env.uat pnpm e2e:playwright:uat

BASE_URL=https://uat-talentcloud.tbs-sct.gc.ca

# Shared secret for the /refresh token-minting endpoint (Azure Key Vault: testing-endpoint-secret)
TESTING_ENDPOINT_SECRET=

# Sub (subject) identifiers for real UAT users — obtain from a team member
PLAYWRIGHT_PLATFORM_ADMIN_SUB=
PLAYWRIGHT_COMMUNITY_ADMIN_SUB=
PLAYWRIGHT_APPLICANT_SUB=
